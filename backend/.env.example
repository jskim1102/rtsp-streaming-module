# backend/.env — backend 가 읽는 런타임 환경변수 (v2 — WebRTC).
# 실제 값은 backend/.env 에만 (git 에 안 올림). 이 파일은 placeholder + 설명만.
# 권장 로컬 경로는 ./dev.sh up (루트 .env 를 source). 수동 네이티브 실행 시엔 루트 .env 를
# source 하거나 `harness mtx env rtsp-streaming` 출력을 export 해야 공유 mediamtx 값이 채워진다.
# (frontend VITE viewer 자격증명은 프론트 빌드/실행 변수라 이 파일이 아니라 루트 .env 소속.)

# 허용 오리진 (CORS). 비우면 기본 "*" (모든 오리진). 공개배포 시 프론트 origin 으로 한정 권장.
CORS_ORIGINS=*

# 등록 가능한 IP 카메라 최대 대수 (1~64). 비우면 기본 16. 초과 시 POST 409
MAX_IPCAMS=16

# mediamtx API 주소. Docker 는 compose environment 가 http://mediamtx:9997 주입,
# 로컬 실행 시 여기에 설정 (예: http://localhost:10001). 미설정이면 path 등록 실패.
MEDIAMTX_API=

# path 네임스페이스 prefix — models.py _generate_stream_key 가 읽어 stream_key 를
# `<prefix>__ipcam-*` 로 생성(프로젝트간 path 충돌·교차열람 차단). 미설정이면 UNPREFIXED 키라
# 공유 인스턴스 path 격리가 깨진다. 값은 `harness mtx env rtsp-streaming` 출력으로 채운다.
MEDIAMTX_PATH_PREFIX=rtsp_streaming

# 공유 mediamtx 자격증명 — config.py 가 읽어 mediamtx.py 가 API 호출 시 Basic auth 로 사용.
# 비번 비우면 무인증(로컬/테스트 하위호환). 실제 값은 infra 공유값(`harness mtx env rtsp-streaming`).
MEDIAMTX_BACKEND_USER=backend
MEDIAMTX_BACKEND_PASS=

# WebRTC 외부접속 광고 호스트 (공인 IP/도메인). webrtcAdditionalHosts 로 쓰임.
# 미설정이면 외부에서 영상이 안 나올 수 있음 (컨테이너 배포 #1 gotcha).
MEDIAMTX_WEBRTC_HOST=

# 로그 레벨 (비우면 기본 INFO)
LOG_LEVEL=INFO
