# backend/.env — config.py 가 읽는 런타임 환경변수.
# 실제 값은 backend/.env 에만 (git 에 안 올림). 이 파일은 placeholder + 설명만.

# 허용 오리진 (CORS). 기본 "*" (모든 오리진)
CORS_ORIGINS=

# JPEG 인코딩 품질 (1~100, 기본 70)
JPEG_QUALITY=

# 프레임 캡처 간격 초 (0.01~1.0, 기본 0.03 ≈ 33fps)
CAPTURE_INTERVAL=

# 등록 가능한 IP 카메라 최대 대수 (1~64, 기본 16). 초과 시 POST 409
MAX_IPCAMS=

# 로그 레벨 (기본 INFO)
LOG_LEVEL=
