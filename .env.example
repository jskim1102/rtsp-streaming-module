# 모듈 루트 .env — docker-compose 가 읽는 포트 변수. 실제 값은 .env 에만
# (git 에 안 올림, RULES §4.1). 이 파일은 placeholder + 설명만. git 에 올림.
# add-cto 가 PORT_OFFSET/BACKEND_PORT/FRONTEND_PORT 를 .env 에 자동 기록한다.

# CTO 포트 offset (add-cto 자동배정)
PORT_OFFSET=
# backend HTTP port = 8000 + PORT_OFFSET (예: offset=4 → 8004), 컨테이너 8000
BACKEND_PORT=
# frontend port = 5174 + (PORT_OFFSET − 1) (예: offset=4 → 5177), 컨테이너 80
# 주의: offset=2(5175)·offset=5(8005)는 시스템 RESERVED — add-cto 가 자동 스킵
FRONTEND_PORT=

# ── mediamtx (v2 WebRTC/WHEP transcode) — compose 가 필수로 요구하는 포트들 ──
# 미설정 시 compose 가 ${VAR:?} 로 즉시 에러(빈/랜덤 publish 방지, P1-1).
# mediamtx API (control plane) — 호스트 loopback 만 노출. 예: 10000 + PORT_OFFSET → 10004
MEDIAMTX_API_PORT=
# RTSP ingest/republish 포트. 예: 8554 + PORT_OFFSET → 8558
MEDIAMTX_RTSP_PORT=
# WebRTC(WHEP) 포트 — 브라우저가 직접 접속(영상). 예: 8889 + PORT_OFFSET → 8893
MEDIAMTX_WEBRTC_PORT=
# WebRTC ICE UDP mux 포트. 예: 8189 + PORT_OFFSET → 8193
MEDIAMTX_ICE_UDP_PORT=
# WebRTC ICE advertise 호스트(쉼표구분) — 브라우저가 닿을 LAN/공인 IP. 예: 192.168.0.x,<공인IP>
# 미설정이면 mediamtx 가 컨테이너 내부주소만 광고 → 외부에서 영상 안 나옴.
MEDIAMTX_WEBRTC_HOST=

# ── 선택(기본값 있음) ──
# 등록 카메라 cap (1~64, 기본 16). 백엔드 /api/config 로 프론트에 내려감.
MAX_IPCAMS=
# CORS 허용 origin — 인증이 없으므로 공개배포 시 프론트 origin 으로 한정 권장(보안 P1-4).
# 예: http://<공인IP>:5177  (미설정 시 기본 "*" = 모든 origin 허용)
CORS_ORIGINS=
