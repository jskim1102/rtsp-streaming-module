# 모듈 루트 .env 예시. 이 파일을 .env 로 복사한 뒤 빈 값을 직접 채운다.
# .env 는 비밀번호를 포함하므로 git 에 올리지 않는다.

# backend HTTP host port (예: 8004), 컨테이너 8000
BACKEND_PORT=
# frontend HTTP host port (예: 5177), 컨테이너 80
FRONTEND_PORT=

# ── bundled mediamtx ──
# backend 가 compose 내부 DNS 로 자체 mediamtx API 에 접속한다.
MEDIAMTX_API=http://mediamtx:9997
# path 네임스페이스 prefix — viewer 권한의 `~^rtsp_streaming__` 경계와 일치해야 한다.
MEDIAMTX_PATH_PREFIX=rtsp_streaming
# WebRTC(WHEP) host port. docker-compose.yml 의 고정 publish 포트와 일치한다.
MEDIAMTX_WEBRTC_PORT=8889
# WebRTC ICE advertise 호스트 — 이 Docker host 의 LAN IP(예: 192.168.0.20)를 입력한다.
# 다른 PC에서 보려면 방화벽/라우터에서 8889/tcp와 8189/udp도 열어야 한다.
MEDIAMTX_WEBRTC_HOST=
# 서로 다른 강한 비밀번호를 직접 정한다. 빈 값이면 compose 가 명시적으로 실패한다.
MEDIAMTX_BACKEND_USER=backend
MEDIAMTX_BACKEND_PASS=
MEDIAMTX_VIEWER_USER=viewer_rtsp_streaming
MEDIAMTX_VIEWER_PASS=

# ── 선택(기본값 있음) ──
# 등록 카메라 cap (1~64, 비우면 기본 16). 백엔드 /api/config 로 프론트에 내려감.
MAX_IPCAMS=
# CORS 허용 origin — 인증이 없으므로 공개배포 시 프론트 origin 으로 한정 권장(보안 P1-4).
# 예: http://<공인IP>:5177  (미설정 시 기본 "*" = 모든 origin 허용)
CORS_ORIGINS=
