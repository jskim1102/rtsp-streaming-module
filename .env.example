# 모듈 루트 .env — docker-compose 가 읽는 포트 변수. 실제 값은 .env 에만
# (git 에 안 올림, RULES §4.1). 이 파일은 placeholder + 설명만. git 에 올림.
# add-cto 가 PORT_OFFSET/BACKEND_PORT/FRONTEND_PORT 를 .env 에 자동 기록한다.

# CTO 포트 offset (add-cto 자동배정)
PORT_OFFSET=
# backend HTTP port = 8000 + PORT_OFFSET (예: offset=4 → 8004), 컨테이너 8000
BACKEND_PORT=
# frontend port = 5174 + (PORT_OFFSET − 1) (예: offset=4 → 5177), 컨테이너 80
# 주의: offset=2(5175)·offset=5(8005)는 시스템 RESERVED — add-cto 가 자동 스킵
FRONTEND_PORT=

# ── mediamtx — 공유 인스턴스 harness-shared-mediamtx 사용 (CEO #115) ──
# per-project mediamtx 제거 — 모든 모듈이 공유 인스턴스에 path-prefix 네임스페이싱으로 입주.
# 아래 값은 `harness mtx env rtsp-streaming` 출력으로 채운다(비번=infra/.env 공유값, 출력 금지).
# MEDIAMTX_API: compose=docker DNS(http://harness-shared-mediamtx:9997), 네이티브 dev=http://127.0.0.1:9997(dev.sh override).
MEDIAMTX_API=
# path 네임스페이스 prefix — stream_key 가 `<prefix>__ipcam-*` 로 생성/저장(프로젝트간 교차열람 차단).
MEDIAMTX_PATH_PREFIX=rtsp_streaming
# WebRTC(WHEP) 포트 — 브라우저 직접 접속(영상). 공유 인스턴스 8889. frontend 빌드 인라인용.
MEDIAMTX_WEBRTC_PORT=8889
# WebRTC ICE advertise 호스트(쉼표구분) — 브라우저가 닿을 LAN/공인 IP. 미설정이면 외부영상 안 나옴.
MEDIAMTX_WEBRTC_HOST=
# 공유 mediamtx 자격증명 (infra/.env 공유값). backend=API/publish/read, viewer=이 프로젝트 WHEP read 전용.
MEDIAMTX_BACKEND_USER=backend
MEDIAMTX_BACKEND_PASS=
MEDIAMTX_VIEWER_USER=viewer_rtsp_streaming
MEDIAMTX_VIEWER_PASS=

# ── 선택(기본값 있음) ──
# 등록 카메라 cap (1~64, 기본 16). 백엔드 /api/config 로 프론트에 내려감.
MAX_IPCAMS=
# CORS 허용 origin — 인증이 없으므로 공개배포 시 프론트 origin 으로 한정 권장(보안 P1-4).
# 예: http://<공인IP>:5177  (미설정 시 기본 "*" = 모든 origin 허용)
CORS_ORIGINS=
